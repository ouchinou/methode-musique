---
// src/pages/batterie/adulte/index.astro
// Modifie "batterie" dans le glob ci-dessous si tu adaptes ce fichier pour un autre instrument (piano, basse, etc.)
const lecons = await Astro.glob('./*.md');

// On trie les leçons par ordre alphabétique ou numérique de leur URL pour éviter le désordre
const leconsTriees = lecons.sort((a, b) => a.url.localeCompare(b.url));
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>Cours de Batterie - Adultes</title>
  </head>
  <body>
    <main class="hub-container">
      <nav><a href="/">← Retour à l'accueil</a></nav>
      
      <h1>🥁 Méthode de Batterie (Adultes)</h1>
      <p class="intro">Progresse à ton rythme à travers nos leçons interactives.</p>

      <div class="lecons-list">
        {leconsTriees.map((lecon, index) => (
          <a href={lecon.url} class="lecon-card">
            <span class="badge">Leçon {index + 1}</span>
            <h2>{lecon.frontmatter.title.replace(/Leçon \d+\s*:\s*/, '') || "Sans titre"}</h2>
            <span class="arrow">Démarrer →</span>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>

<style>
  body {
    background-color: #0f172a;
    color: #f8fafc;
    font-family: system-ui, sans-serif;
    padding: 40px 20px;
  }
  .hub-container {
    max-width: 800px;
    margin: 0 auto;
  }
  nav a {
    color: #38bdf8;
    text-decoration: none;
  }
  h1 {
    font-size: 2.5rem;
    color: #38bdf8;
    margin-top: 20px;
    margin-bottom: 10px;
  }
  .intro {
    color: #94a3b8;
    margin-bottom: 40px;
  }
  .lecons-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .lecon-card {
    display: flex;
    align-items: center;
    background-color: #1e293b;
    border: 1px solid #334155;
    padding: 20px;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.2s, transform 0.2s;
  }
  .lecon-card:hover {
    background-color: #1e293b90;
    transform: translateX(5px);
    border-color: #38bdf8;
  }
  .badge {
    background-color: #38bdf8;
    color: #0f172a;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: bold;
    margin-right: 20px;
  }
  .lecon-card h2 {
    margin: 0;
    font-size: 1.2rem;
    flex-grow: 1;
  }
  .arrow {
    color: #38bdf8;
    font-weight: bold;
  }
</style>