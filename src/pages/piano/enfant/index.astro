---
const title = "L'Île aux Pianos 🌟";

const leçons = [
  {
    id: 1,
    titre: "La Maison des Notes",
    description: "Apprends à retrouver le Do avec l'aide des deux touches noires et du petit chat !",
    duree: "10 min",
    badge: "Débutant",
    lien: "/methode-musique/piano/enfant/lecon1", // 🌟 Lien mis à jour vers le piano enfant
    emoji: "🐱"
  },
  {
    id: 2,
    titre: "La Ballade des Grenouilles",
    description: "Fais sauter tes doigts d'une touche à l'autre sans jamais te presser.",
    duree: "15 min",
    badge: "Moyen",
    lien: "/methode-musique/piano/enfant/lecon2", // 🌟 Lien mis à jour vers le piano enfant
    emoji: "🐸"
  },
  {
    id: 3,
    titre: "Le Rythme Magique",
    description: "Joue une mélodie simple sur un rythme entraînant !",
    duree: "15 min",
    badge: "Rythme",
    lien: "/methode-musique/piano/enfant/rythme", // 🌟 Lien vers rythme.astro dans piano/enfant
    emoji: "🎶"
  }
];
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<div class="layout-container">
			<nav class="top-nav">
				<a href="/methode-musique/piano" class="back-link">← Changer de parcours</a>
				<span class="badge-status">Espace Enfants 🎈</span>
			</nav>

			<main class="content">
				<header class="hero">
					<h1>Bienvenue sur l'Île aux Pianos !</h1>
					<p class="subtitle">Ici, chaque touche raconte une histoire. Prêt à jouer ta première mélodie avec les animaux ?</p>
				</header>

				<section class="modules-list">
					<h2>Tes Missions de Pianiste 🎹</h2>
					<div class="grid">
						{leçons.map((lecon) => (
							<div class="module-card">
								<div class="card-header">
									<span class="module-number">Mission {lecon.id}</span>
									<span class="emoji-indicator">{lecon.emoji}</span>
								</div>
								<div class="card-body">
									<h3>{lecon.titre}</h3>
									<p>{lecon.description}</p>
								</div>
								<div class="card-footer">
									<div class="meta">
										<span>⏱️ {lecon.duree}</span>
										<span>🎨 {lecon.badge}</span>
									</div>
									<a href={lecon.lien} class="action-btn">Jouer !</a>
								</div>
							</div>
						))}
					</div>
				</section>
			</main>
		</div>
	</body>
</html>

<style>
	:root {
		--bg: #0b1329;
		--card-bg: #1c2541;
		--border: #3a506b;
		--text: #ffffff;
		--text-muted: #a5b1c2;
		--accent-enfant: #10b981;
		--accent-hover: #059669;
	}

	* { box-sizing: border-box; margin: 0; padding: 0; }

	body {
		background-color: var(--bg);
		color: var(--text);
		font-family: 'Comic Sans MS', 'Inter', system-ui, sans-serif;
		min-height: 100vh;
	}

	.layout-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 24px;
	}

	.top-nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 40px;
	}

	.back-link {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 1rem;
		font-weight: bold;
		transition: color 0.2s;
	}
	.back-link:hover { color: var(--accent-enfant); }

	.badge-status {
		background-color: rgba(16, 185, 129, 0.15);
		color: var(--accent-enfant);
		padding: 8px 16px;
		border-radius: 9999px;
		font-size: 0.9rem;
		font-weight: 700;
	}

	.hero { margin-bottom: 40px; text-align: center; }
	
	h1 {
		font-size: 2.3rem;
		font-weight: 900;
		margin-bottom: 15px;
		color: #f472b6; /* Un joli rose doux pour le piano enfant */
		text-shadow: 0 4px 6px rgba(0,0,0,0.2);
	}

	.subtitle {
		font-size: 1.1rem;
		color: var(--text-muted);
		line-height: 1.5;
	}

	h2 {
		font-size: 1.6rem;
		font-weight: 800;
		margin-bottom: 24px;
		color: var(--accent-enfant);
	}

	.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px; }

	.module-card {
		background-color: var(--card-bg);
		border: 3px solid var(--border);
		border-radius: 24px;
		padding: 24px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 16px;
		transition: transform 0.2s, border-color 0.2s;
	}
	.module-card:hover {
		transform: scale(1.02);
		border-color: var(--accent-enfant);
	}

	.card-header { display: flex; justify-content: space-between; align-items: center; }
	.module-number { font-size: 0.85rem; font-weight: 800; color: #f472b6; text-transform: uppercase; }
	.emoji-indicator { font-size: 2rem; }

	h3 { font-size: 1.3rem; font-weight: 800; margin-bottom: 8px; }
	.card-body p { color: var(--text-muted); line-height: 1.5; font-size: 0.95rem; }

	.card-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-top: 2px dashed var(--border);
		padding-top: 16px;
		margin-top: 10px;
	}

	.meta { display: flex; flex-direction: column; gap: 4px; font-size: 0.85rem; color: var(--text-muted); font-weight: bold; }

	.action-btn {
		background-color: var(--accent-enfant);
		color: #0b1329;
		padding: 10px 20px;
		border-radius: 20px;
		font-weight: 900;
		text-decoration: none;
		font-size: 1rem;
		box-shadow: 0 4px 0 #059669;
		transition: transform 0.1s, box-shadow 0.1s;
	}
	.action-btn:active {
		transform: translateY(4px);
		box-shadow: 0 0px 0 #059669;
	}
</style>