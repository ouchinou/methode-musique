---
// Code serveur (exécuté à la compilation)
const title = "Méthode de Musique Interactive";
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<main class="welcome-container">
			<header class="hero">
				<span class="emoji">🎵</span>
				<h1>{title}</h1>
				<p class="subtitle">Choisissez votre parcours pour commencer à jouer</p>
			</header>

			<div class="choices-grid">
				<!-- Option Enfants -->
				<a href="/methode-musique/enfant" class="card card-enfant">
					<div class="card-content">
						<span class="card-emoji">🎈</span>
						<h2>Parcours Enfants</h2>
						<p>Apprendre en s'amusant avec des jeux de rythme et des leçons colorées !</p>
						<span class="btn">C'est parti !</span>
					</div>
				</a>

				<!-- Option Adultes -->
				<a href="/methode-musique/adulte" class="card card-adulte">
					<div class="card-content">
						<span class="card-emoji">🎹</span>
						<h2>Parcours Adultes</h2>
						<p>Une méthode structurée, de la technique, du rythme et des morceaux avec accompagnement IA.</p>
						<span class="btn">Découvrir la méthode</span>
					</div>
				</a>
			</div>
		</main>
	</body>
</html>

<style>
	:root {
		--bg-dark: #121214;
		--card-bg: #1e1e24;
		--accent-enfant: #ff4081;
		--accent-adulte: #4fc3f7;
		--text-light: #ffffff;
		--text-muted: #8a8a93;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		background-color: var(--bg-dark);
		color: var(--text-light);
		font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.welcome-container {
		max-width: 900px;
		width: 100%;
		padding: 40px 20px;
		text-align: center;
	}

	.hero {
		margin-bottom: 50px;
	}

	.emoji {
		font-size: 4rem;
		display: inline-block;
		margin-bottom: 10px;
		animation: bounce 2s infinite ease-in-out;
	}

	h1 {
		font-size: 2.8rem;
		font-weight: 800;
		margin-bottom: 15px;
		background: linear-gradient(45deg, var(--accent-adulte), #b388ff);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.subtitle {
		font-size: 1.2rem;
		color: var(--text-muted);
	}

	.choices-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 30px;
		margin-top: 20px;
	}

	.card {
		background-color: var(--card-bg);
		border-radius: 20px;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		position: relative;
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
		border: 1px solid #2d2d38;
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.card:hover {
		transform: translateY(-8px);
	}

	.card-enfant:hover {
		box-shadow: 0 15px 30px rgba(255, 64, 129, 0.2);
		border-color: var(--accent-enfant);
	}

	.card-adulte:hover {
		box-shadow: 0 15px 30px rgba(79, 195, 247, 0.2);
		border-color: var(--accent-adulte);
	}

	.card-content {
		padding: 40px 30px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: space-between;
		height: 100%;
		gap: 15px;
	}

	.card-emoji {
		font-size: 3rem;
		margin-bottom: 10px;
	}

	h2 {
		font-size: 1.6rem;
		font-weight: 700;
	}

	p {
		font-size: 1rem;
		color: var(--text-muted);
		line-height: 1.5;
		margin-bottom: 15px;
	}

	.btn {
		display: inline-block;
		padding: 12px 24px;
		border-radius: 25px;
		font-weight: 700;
		font-size: 0.95rem;
		transition: background-color 0.2s, transform 0.1s;
		width: 100%;
	}

	.card-enfant .btn {
		background-color: var(--accent-enfant);
		color: white;
	}

	.card-adulte .btn {
		background-color: var(--accent-adulte);
		color: #121214;
	}

	@keyframes bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-10px); }
	}
</style>