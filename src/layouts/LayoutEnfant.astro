---
// src/layouts/LayoutEnfant.astro
const { frontmatter } = Astro.props;

const urlRetour = frontmatter.urlRetour || "/methode-musique/";
const labelRetour = frontmatter.labelRetour || "Retour aux cours";
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{frontmatter.title}</title>
  </head>
  <body>
    <nav class="layout-nav">
      <!-- Un bouton de retour plus gros et ludique pour les enfants -->
      <a href={urlRetour} class="btn-retour">🎒 {labelRetour}</a>
    </nav>

    <main class="layout-content">
      <slot /> 
    </main>
  </body>
</html>

<style>
  body {
    background-color: #fefcf6; /* Un fond crème plus doux pour les yeux des enfants */
    color: #1e293b; /* Texte sombre pour un super contraste */
    font-family: 'Comic Sans MS', system-ui, sans-serif; /* Optionnel : une police plus "ronde" */
    padding: 30px 15px;
    font-size: 1.1rem; /* Texte un poil plus grand pour faciliter la lecture */
  }
  .layout-nav {
    max-width: 750px;
    margin: 0 auto 40px auto;
  }
  .btn-retour {
    display: inline-block;
    background-color: #f59e0b; /* Bouton orange sympa */
    color: white;
    padding: 10px 20px;
    border-radius: 20px;
    text-decoration: none;
    font-weight: bold;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s;
  }
  .btn-retour:hover {
    transform: scale(1.05);
  }
  .layout-content {
    max-width: 750px;
    margin: 0 auto;
    line-height: 1.8;
  }
  /* Styles Markdown adaptés aux enfants (plus colorés et aérés) */
  .layout-content h1 { font-size: 2.4rem; margin-bottom: 25px; color: #d97706; text-align: center; }
  .layout-content h2 { font-size: 1.8rem; margin-top: 40px; margin-bottom: 20px; color: #0284c7; border-bottom: 3px dashed #e2e8f0; padding-bottom: 8px; }
  .layout-content p { margin-bottom: 20px; }
  .layout-content ul, .layout-content ol { margin-left: 25px; margin-bottom: 20px; }
  .layout-content li { margin-bottom: 10px; }
</style>